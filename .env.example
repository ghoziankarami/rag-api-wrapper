# RAG API Wrapper Configuration
# Copy this file to .env and update values

# API Key for Vercel RAG Dashboard to authenticate
# Generate a secure random string
RAG_API_KEY=your-secret-api-key-here

# Server Port (default: 3004)
PORT=3004

# OpenRouter API key for LLM-backed answers
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Public RAG answer model
# Recommended: zai/glm-5 for stronger follow-up reasoning and longer context handling
OPENROUTER_MODEL=z-ai/glm-5
