# RAG API Wrapper Configuration
# Copy this file to .env and update values

# API Key for Vercel RAG Dashboard to authenticate
# Generate a secure random string
RAG_API_KEY=your-secret-api-key-here

# Server Port (default: 3004)
PORT=3004

# Native Z.ai configuration for LLM-backed answers
ZAI_API_KEY=your-native-zai-api-key-here
ZAI_URL=https://api.z.ai/api/coding/paas/v4/chat/completions

# Public RAG answer model
# Current default: native Z.ai glm-4.7-flash
ZAI_MODEL=glm-4.7-flash
